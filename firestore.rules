/**
 * This ruleset enforces a security model based on user ownership and global administrative roles for a library visit tracking system.
 *
 * Core Philosophy:
 * The primary security goal is to ensure that users can only access and manage their own data, while granting administrators global oversight and management capabilities. The rules default to denying access, only permitting actions that are explicitly allowed.
 *
 * Data Structure:
 * - /users/{userId}: Each user has a root profile document. The document ID matches their authentication UID.
 * - /users/{userId}/libraryVisits/{visitId}: A user's library visit history is stored in a nested subcollection.
 * - /colleges/{collegeId} & /visitReasons/{reasonId}: These are top-level collections for system-wide lookup data (e.g., lists of colleges, reasons for visits).
 *
 * Key Security Decisions:
 * - Admin Role Management: A user is considered an administrator if their user document has role == 'admin'.
 * - User Privacy: Users are strictly prohibited from listing or viewing other users' profiles or visit histories.
 * - Role Escalation Prevention: A crucial rule prevents non-admin users from changing their own 'role' field, blocking a common privilege escalation vector.
 * - Ownership Integrity: Rules enforce that when a user creates a subcollection document (like a library visit), the document's internal `userId` field must match the user's UID, ensuring data integrity.
 *
 * Denormalization for Authorization:
 * To ensure performant and secure rules, especially for administrator queries that scan across all users' data (Collection Group Queries), the `userId` is denormalized (copied) into each `libraryVisits` document. This allows a rule to verify ownership directly from the document itself without needing a slow and costly `get()` call to its parent `user` document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the document ID in the path.
     * This is the primary function for establishing document ownership.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Checks if the current user has an 'admin' role in their profile.
     * This provides a performant check for global administrative privileges.
     */
    function isAdmin() {
      // A user is an admin if their profile document has the role 'admin'.
      // This requires a get() call, which has cost implications but is necessary for role-based access.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Verifies that a document exists before an update or delete operation.
     * This is a critical check to ensure rules are not bypassed on non-existent paths.
     */
    function isExistingDoc() {
      return resource != null;
    }
    
    // Collection Group for all library visits
    match /{path=**}/libraryVisits/{visitId} {
      // Admins can list all visits across all users for reporting purposes.
      allow list: if isAdmin();
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    /**
     * @description Manages user profiles. Users can create, read, and update their own profile. Admins have full access.
     * @path /users/{userId}
     */
    match /users/{userId} {
      // Users can read their own profile, Admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can list all users.
      allow list: if isAdmin();
      
      // A new user can create their own profile document.
      // - The document ID must match their authentication UID.
      // - The 'role' must be explicitly set to 'user' to prevent self-assignment of admin roles.
      allow create: if isOwner(userId) && 
                      request.resource.data.id == userId &&
                      request.resource.data.role == 'user';
                      
      // Update access is granted if:
      // 1. The document already exists.
      // 2. The user ID in the document cannot be changed.
      // 3. EITHER the request is from an admin, OR it's from the document owner AND they are not changing their own role.
      // This prevents users from escalating their own privileges.
      allow update: if isExistingDoc() &&
                      request.resource.data.id == resource.data.id &&
                      (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));

      // Only admins can delete user profiles.
      allow delete: if isAdmin() && isExistingDoc();

      /**
       * @description Manages library visit records, nested under a user. Users can manage their own visits. Admins have read access for reporting.
       * @path /users/{userId}/libraryVisits/{visitId}
       */
      match /libraryVisits/{visitId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        // The userId within the visit log must match the creator's UID.
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        // The userId within the visit log cannot be changed.
        allow update: if (isOwner(userId) || isAdmin()) && isExistingDoc() && request.resource.data.userId == resource.data.userId;
        allow delete: if (isOwner(userId) || isAdmin()) && isExistingDoc();
      }
    }

    /**
     * @description Manages college lookup data. Readable by all authenticated users, but writable only by administrators.
     * @path /colleges/{collegeId}
     */
    match /colleges/{collegeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    /**
     * @description Manages visit reason lookup data. Readable by all authenticated users, writable only by admins.
     * @path /visitReasons/{reasonId}
     */
    match /visitReasons/{reasonId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }
  }
}

    
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The rules below are temporarily set to be fully open for development purposes.
    // They allow all reads and writes to all collections, which is insecure for a
    // production environment. These will be replaced with secure rules later.

    match /users/{userId} {
      allow read, write: if true;
    }

    match /roles_admin/{userId} {
      allow read, write: if true;
    }

    match /visit_logs/{visitLogId} {
      allow read, write: if true;
    }

    match /colleges/{collegeId} {
      allow read, write: if true;
    }
  }
}
